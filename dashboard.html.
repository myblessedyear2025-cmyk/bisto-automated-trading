<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bisto Dashboard</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
background:#06121f;
color:#fff;
display:flex;
}

.sidebar{
width:280px;
height:100vh;
position:fixed;
background:#08131f;
padding:30px;
display:flex;
flex-direction:column;
}

.logo{
font-size:34px;
font-weight:800;
color:#1da1ff;
margin-bottom:40px;
}

.sidebar a{
padding:16px 20px;
margin:8px 0;
color:white;
text-decoration:none;
border-radius:15px;
transition:.35s;
display:flex;
align-items:center;
gap:15px;
}

.sidebar a:hover{
background:#1da1ff;
color:#071320;
transform:translateX(8px);
}

.main{
margin-left:280px;
width:100%;
padding:40px;
}

.topbar{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:35px;
}

.search{
background:#0d1d2d;
padding:15px 20px;
border-radius:40px;
width:350px;
border:none;
color:white;
outline:none;
}

.profile{
display:flex;
align-items:center;
gap:15px;
}

.avatar{
width:50px;
height:50px;
border-radius:50%;
background:#1da1ff;
display:flex;
justify-content:center;
align-items:center;
font-weight:700;
font-size:20px;
color:#071320;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
gap:25px;
}

.card{
background:#0d1d2d;
padding:28px;
border-radius:25px;
transition:.4s;
}

.card:hover{
transform:translateY(-10px);
box-shadow:0 25px 50px rgba(29,161,255,.25);
}

.card h4{
color:#8cb3d9;
margin-bottom:15px;
}

.card h2{
font-size:34px;
color:#1da1ff;
}

.market{
margin-top:40px;
background:#0d1d2d;
border-radius:30px;
padding:30px;
}

.market svg{
width:100%;
height:300px;
}

.graph{
fill:none;
stroke:#1da1ff;
stroke-width:5;
stroke-linecap:round;
stroke-linejoin:round;
stroke-dasharray:1500;
stroke-dashoffset:1500;
animation:draw 5s linear infinite;
}

@keyframes draw{

0%{stroke-dashoffset:1500;}

100%{stroke-dashoffset:0;}

}

.transactions{

margin-top:40px;

background:#0d1d2d;

border-radius:30px;

padding:30px;

}

table{

width:100%;

border-collapse:collapse;

}

th,td{

padding:18px;

text-align:left;

}

th{

color:#1da1ff;

}

tr{

border-bottom:1px solid rgba(255,255,255,.08);

}

.status{

padding:8px 18px;

border-radius:20px;

background:#00b35f;

display:inline-block;

}

@media(max-width:900px){

.sidebar{

width:90px;

}

.sidebar span{

display:none;

}

.main{

margin-left:90px;

}

.search{

display:none;

}

}

</style>

</head>

<body>

<div class="sidebar">

<div class="logo">BISTO</div>

<a href="#"><i class="fas fa-chart-line"></i><span>Dashboard</span></a>

<a href="#"><i class="fas fa-wallet"></i><span>Wallet</span></a>

<a href="#"><i class="fas fa-arrow-down"></i><span>Deposit</span></a>

<a href="#"><i class="fas fa-arrow-up"></i><span>Withdraw</span></a>

<a href="#"><i class="fas fa-coins"></i><span>Investments</span></a>

<a href="#"><i class="fas fa-clock"></i><span>History</span></a>

<a href="#"><i class="fas fa-user"></i><span>Profile</span></a>

<a href="index.html"><i class="fas fa-right-from-bracket"></i><span>Logout</span></a>

</div>

<div class="main">

<div class="topbar">

<input class="search" placeholder="Search...">

<div class="profile">

<div class="avatar">B</div>

<div>

<h3>Welcome Back</h3>

<p>Premium Investor</p>

</div>

</div>

</div>

<div class="cards">

<div class="card">

<h4>Total Balance</h4>

<h2>$25,820</h2>

</div>

<div class="card">

<h4>Today's Profit</h4>

<h2>$1,285</h2>

</div>

<div class="card">

<h4>Active Investments</h4>

<h2>7</h2>

</div>

<div class="card">

<h4>Referral Earnings</h4>

<h2>$2,540</h2>

</div>

</div>

<div class="market">

<h2 style="margin-bottom:20px;">Live Portfolio Performance</h2>

<svg viewBox="0 0 900 300">

<path class="graph"

d="M0 260
L70 250
L140 235
L210 220
L280 180
L350 195
L420 150
L490 160
L560 110
L630 120
L700 70
L770 85
L840 30
L900 10"/>

</svg>

</div>

<div class="transactions">

<h2 style="margin-bottom:20px;">Recent Transactions</h2>

<table>

<tr>

<th>Date</th>

<th>Type</th>

<th>Amount</th>

<th>Status</th>

</tr>

<tr>

<td>14 Jul 2026</td>

<td>Deposit</td>

<td>$2,000</td>

<td><span class="status">Completed</span></td>

</tr>

<tr>

<td>13 Jul 2026</td>

<td>Investment</td>

<td>$5,000</td>

<td><span class="status">Running</span></td>

</tr>

<tr>

<td>12 Jul 2026</td>

<td>Withdrawal</td>

<td>$600</td>

<td><span class="status">Completed</span></td>

</tr>

</table>

</div>

</div>

</body>
</html>
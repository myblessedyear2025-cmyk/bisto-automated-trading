<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bisto Dashboard</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Poppins,sans-serif;
}

body{
background:#071320;
color:white;
display:flex;
}

.sidebar{
width:250px;
height:100vh;
background:#0d1e2f;
position:fixed;
padding:30px 20px;
}

.logo{
font-size:28px;
font-weight:700;
color:#2aa9ff;
margin-bottom:40px;
text-align:center;
}

.sidebar a{
display:block;
padding:15px;
margin:10px 0;
border-radius:12px;
color:white;
text-decoration:none;
transition:.3s;
}

.sidebar a:hover{
background:#2aa9ff;
color:#071320;
}

.main{
margin-left:250px;
padding:40px;
width:100%;
}

.top{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:40px;
}

.user{
font-size:18px;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
}

.card{
background:#102235;
padding:25px;
border-radius:20px;
box-shadow:0 0 20px rgba(42,169,255,.15);
}

.card h4{
color:#2aa9ff;
margin-bottom:10px;
}

.card h2{
font-size:34px;
}

.actions{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
gap:20px;
margin-top:40px;
}

button{
padding:16px;
border:none;
border-radius:12px;
background:#2aa9ff;
font-weight:700;
cursor:pointer;
font-size:16px;
}

button:hover{
background:#1d8de0;
}

table{
width:100%;
margin-top:40px;
border-collapse:collapse;
background:#102235;
border-radius:20px;
overflow:hidden;
}

th,td{
padding:18px;
text-align:left;
}

th{
background:#2aa9ff;
color:#071320;
}

tr:nth-child(even){
background:#15293f;
}

@media(max-width:900px){

.sidebar{
width:80px;
}

.sidebar a{
font-size:12px;
padding:10px;
}

.logo{
font-size:18px;
}

.main{
margin-left:80px;
}

}

</style>

</head>

<body>

<div class="sidebar">

<div class="logo">BISTO</div>

<a href="#">Dashboard</a>
<a href="#">Deposit</a>
<a href="#">Withdraw</a>
<a href="#">Investments</a>
<a href="#">History</a>
<a href="#">Profile</a>
<a href="index.html">Logout</a>

</div>

<div class="main">

<div class="top">

<h1>Dashboard</h1>

<div class="user">

Welcome, Investor 👋

</div>

</div>

<div class="cards">

<div class="card">

<h4>Wallet Balance</h4>

<h2>$12,540.00</h2>

</div>

<div class="card">

<h4>Total Profit</h4>

<h2>$3,285.00</h2>

</div>

<div class="card">

<h4>Active Plans</h4>

<h2>3</h2>

</div>

<div class="card">

<h4>Referral Bonus</h4>

<h2>$480.00</h2>

</div>

</div>

<div class="actions">

<button>Deposit Funds</button>

<button>Withdraw</button>

<button>Start Investment</button>

<button>Edit Profile</button>

</div>

<h2 style="margin-top:50px;">Recent Transactions</h2>

<table>

<tr>

<th>Date</th>

<th>Type</th>

<th>Amount</th>

<th>Status</th>

</tr>

<tr>

<td>14 Jul 2026</td>

<td>Deposit</td>

<td>$500</td>

<td>Completed</td>

</tr>

<tr>

<td>12 Jul 2026</td>

<td>Withdrawal</td>

<td>$150</td>

<td>Pending</td>

</tr>

<tr>

<td>10 Jul 2026</td>

<td>Investment</td>

<td>$1000</td>

<td>Running</td>

</tr>

</table>

</div>

</body>
</html>